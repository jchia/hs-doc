packages: .
with-compiler: ghc-9.12.4

source-repository-package
    type: git
    location: https://github.com/tusharad/ollama-haskell.git
    tag: 33807a3a5a507e99d92b26e245c0aed582fde581

source-repository-package
    type: git
    location: https://github.com/serokell/universum.git
    tag: faacef14aee313ec6ec69bc813f12934f1c04840

package *
    documentation: true
    haddock-options: --hoogle

package amazonka-s3
  ghc-options: -XDuplicateRecordFields
  haddock-options: --optghc=-XDuplicateRecordFields

package amazonka-sso
  ghc-options: -XDuplicateRecordFields
  haddock-options: --optghc=-XDuplicateRecordFields

package amazonka-sts
  ghc-options: -XDuplicateRecordFields
  haddock-options: --optghc=-XDuplicateRecordFields

constraints:
  openai < 2.5

allow-newer:
  amazonka:base,
  amazonka-core:base,
  amazonka-core:containers,
  amazonka-s3:base,
  amazonka-sts:base,
  amazonka-sso:base,
  nanovg:containers,
